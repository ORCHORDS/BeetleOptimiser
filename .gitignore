# Node / npm
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build output
dist/
out/

# Build assets are tracked (electron-builder reads build/icon.ico + build/icon.png),
# so don't ignore the whole build/ directory - just the per-machine
# intermediates like debug logs that may appear here.
# 'build/' is intentionally NOT in this list.

# Electron
*.log
**/.DS_Store
Thumbs.db

# Local dev
.vscode/
.idea/
*.swp
*.swo
*.local

# Anthropic's Claude dev workspace (per-machine, NOT for the public repo).
# The .claude/launch.json was accidentally tracked early on; untracked below.
.claude/

# Editor scratch
*.tmp
*.bak
*.orig

# LLM-training pipeline (kept locally for the maintainer's reference, not
# part of the public product - it's a separate project that scrapes
# Microsoft docs + the app's own RAG articles to fine-tune a local LLM).
llm-training/

# Local env files that PowerShell / scripts / CI secrets may use.
# Catch-all .env* with an exception for the example-template file (it's
# safe to commit .env.example as documentation of which keys exist).
.env*
!.env.example

# Local LLM model weights
models/
